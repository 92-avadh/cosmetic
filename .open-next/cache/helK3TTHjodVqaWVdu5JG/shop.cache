 border-none bg-transparent\" aria-label=\"Wishlist\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-heart w-5 h-5 stroke-[1.5]\" aria-hidden=\"true\"><path d=\"M2 9.5a5.5 5.5 0 0 1 9.591-3.676.56.56 0 0 0 .818 0A5.49 5.49 0 0 1 22 9.5c0 2.29-1.5 4-3 5.5l-5.492 5.313a2 2 0 0 1-3 .019L5 15c-1.5-1.5-3-3.2-3-5.5\"></path></svg></button><button class=\"relative p-2 text-ink hover:text-accent transition-colors cursor-pointer border-none bg-transparent\" aria-label=\"Shopping Cart\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"w-5 h-5\"><path d=\"M9 9a3 3 0 0 1 6 0\"></path><path d=\"M7 9h10a2 2 0 0 1 2 1.8l1 7.2a4 4 0 0 1-4 4.5H8a4 4 0 0 1-4-4.5l1-7.2A2 2 0 0 1 7 9z\" style=\"transform-origin:50% 100% 0\"></path><path d=\"M9 12a3 3 0 0 0 6 0\"></path></svg></button><button class=\"p-2 text-ink hover:text-accent transition-colors cursor-pointer\" aria-label=\"Open navigation menu\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-menu w-5 h-5\" aria-hidden=\"true\"><path d=\"M4 5h16\"></path><path d=\"M4 12h16\"></path><path d=\"M4 19h16\"></path></svg></button></div></div></div></header><main class=\"bg-bg text-ink min-h-screen pt-32 pb-24 font-sans\"><div class=\"max-w-7xl mx-auto px-6 md:px-12\"><div class=\"flex flex-wrap items-center gap-2 mb-12 border-b border-line pb-6\"><button class=\"button px-6 py-2.5 text-xs font-semibold tracking-widest uppercase transition-colors duration-200 border rounded-full bg-ink text-bg border-ink\">All Products</button><button class=\"button px-6 py-2.5 text-xs font-semibold tracking-widest uppercase transition-colors duration-200 border rounded-full bg-transparent text-ink/75 border-line hover:border-ink hover:text-ink\">Hydra-Active Wash</button><button class=\"button px-6 py-2.5 text-xs font-semibold tracking-widest uppercase transition-colors duration-200 border rounded-full bg-transparent text-ink/75 border-line hover:border-ink hover:text-ink\">Targeted Body Wash</button></div><div class=\"grid grid-cols-1 lg:grid-cols-12 gap-12 mt-8\"><div class=\"lg:col-span-4 space-y-6 lg:sticky lg:top-24 h-fit\"><h2 class=\"font-display font-semibold text-3xl md:text-4xl uppercase tracking-tight text-accent flex items-center gap-2\"><span class=\"text-accent font-sans\">•</span> OUR PRODUCTS</h2><div class=\"space-y-4 text-xs sm:text-sm text-muted leading-relaxed max-w-sm\"><p>Korean formulation science emphasises how skin behaves, not how it appears.</p><p>This is why Korean formulas lead in barrier-first design, advanced delivery systems, and recovery-focused body care.</p></div></div><div class=\"lg:col-span-8\"><div class=\"grid grid-cols-1 sm:grid-cols-2 gap-8\"><div class=\"border border-line/40 rounded-2xl p-4 bg-card-bg/40 animate-pulse space-y-4\"><div class=\"aspect-[4/5] bg-line/25 rounded-xl w-full\"></div><div class=\"space-y-2\"><div class=\"h-4 bg-line/25 rounded w-2/3\"></div><div class=\"h-3 bg-line/20 rounded w-1/2\"></div></div><div class=\"flex justify-between items-center pt-2 border-t border-line/10\"><div class=\"h-3.5 bg-line/25 rounded w-1/4\"></div><div class=\"h-8 bg-line/25 rounded-full w-24\"></div></div></div><div class=\"border border-line/40 rounded-2xl p-4 bg-card-bg/40 animate-pulse space-y-4\"><div class=\"aspect-[4/5] bg-line/25 rounded-xl w-full\"></div><div class=\"space-y-2\"><div class=\"h-4 bg-line/25 rounded w-2/3\"></div><div class=\"h-3 bg-line/20 rounded w-1/2\"></div></div><div class=\"flex justify-between items-center pt-2 border-t border-line/10\"><div class=\"h-3.5 bg-line/25 rounded w-1/4\"></div><div class=\"h-8 bg-line/25 rounded-full w-24\"></div></div></div><div class=\"border border-line/40 rounded-2xl p-4 bg-card-bg/40 animate-pulse space-y-4\"><div class=\"aspect-[4/5] bg-line/25 rounded-xl w-full\"></div><div class=\"space-y-2\"><div class=\"h-4 bg-line/25 rounded w-2/3\"></div><div class=\"h-3 bg-line/20 rounded w-1/2\"></div></div><div class=\"flex justify-between items-center pt-2 border-t border-line/10\"><div class=\"h-3.5 bg-line/25 rounded w-1/4\"></div><div class=\"h-8 bg-line/25 rounded-full w-24\"></div></div></div><div class=\"border border-line/40 rounded-2xl p-4 bg-card-bg/40 animate-pulse space-y-4\"><div class=\"aspect-[4/5] bg-line/25 rounded-xl w-full\"></div><div class=\"space-y-2\"><div class=\"h-4 bg-line/25 rounded w-2/3\"></div><div class=\"h-3 bg-line/20 rounded w-1/2\"></div></div><div class=\"flex justify-between items-center pt-2 border-t border-line/10\"><div class=\"h-3.5 bg-line/25 rounded w-1/4\"></div><div class=\"h-8 bg-line/25 rounded-full w-24\"></div></div></div></div></div></div></div><section class=\"relative w-full h-[85vh] overflow-hidden bg-card-bg border-y border-line/35 my-24\"><img src=\"/face_wash.png\" alt=\"BODYBARREL - Active Cleansing Campaign\" class=\"w-full h-full object-cover select-none filter contrast-[1.01] brightness-[0.95]\"/><div class=\"absolute inset-0 bg-gradient-to-t from-ink/45 via-transparent to-ink/15 pointer-events-none\"></div><div class=\"absolute bottom-12 left-6 md:left-12 max-w-xl text-bg space-y-4\"><span class=\"text-[10px] uppercase tracking-[0.25em] font-semibold text-accent block\">Dermal Sourcing &amp; Efficacy</span><h3 class=\"font-display font-semibold text-2xl md:text-4xl uppercase tracking-tight leading-tight\">Formulated for high performance. Sourced for skin biological integrity.</h3></div></section><div class=\"max-w-7xl mx-auto px-6 md:px-12\"><section class=\"mt-28 border-t border-line/60 pt-20\"><div class=\"flex flex-col md:flex-row md:items-end justify-between mb-12 space-y-4 md:space-y-0\"><div class=\"space-y-2\"><span class=\"text-xs uppercase tracking-[0.2em] font-semibold text-accent flex items-center gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-sparkles w-3.5 h-3.5\" aria-hidden=\"true\"><path d=\"M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z\"></path><path d=\"M20 2v4\"></path><path d=\"M22 4h-4\"></path><circle cx=\"4\" cy=\"20\" r=\"2\"></circle></svg> Skin System Guide</span><h2 class=\"font-display font-semibold text-2xl md:text-4xl uppercase tracking-tight text-ink\">FIND YOUR RESILIENCE FORMULA</h2></div><p class=\"text-xs md:text-sm text-muted max-w-sm\">Matches developed by biological research to align formulation chemistry with specific epidermal types.</p></div><div class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6\"><div class=\"p-6 bg-card-bg/40 border border-line/40 rounded-xl space-y-4 flex flex-col justify-between hover:border-accent/40 transition-colors duration-300\"><div class=\"space-y-3\"><h3 class=\"font-display font-semibold text-sm tracking-wide uppercase text-ink\">Dry &amp; Damaged</h3><p class=\"text-xs text-muted leading-relaxed\">Requires rich micro-ceramides and amino acids to seal moisture. Avoid high-temperature water.</p></div><div class=\"border-t border-line/30 pt-3 flex items-center justify-between text-[9px] uppercase tracking-widest font-semibold\"><span class=\"text-accent\">Aura-Glow / Bio-Fit</span><span class=\"text-muted/75 font-mono\">5.5 Balanced</span></div></div><div class=\"p-6 bg-card-bg/40 border border-line/40 rounded-xl space-y-4 flex flex-col justify-between hover:border-accent/40 transition-colors duration-300\"><div class=\"space-y-3\"><h3 class=\"font-display font-semibold text-sm tracking-wide uppercase text-ink\">Sensitive &amp; Reacting</h3><p class=\"text-xs text-muted leading-relaxed\">Formulated with soothing marine PDRN and centella extract to reduce epidermal stress and micro-redness.</p></div><div class=\"border-t border-line/30 pt-3 flex items-center justify-between text-[9px] uppercase tracking-widest font-semibold\"><span class=\"text-accent\">Bio-Fit Unisex</span><span class=\"text-muted/75 font-mono\">5.4 Low-Acid</span></div></div><div class=\"p-6 bg-card-bg/40 border border-line/40 rounded-xl space-y-4 flex flex-col justify-between hover:border-accent/40 transition-colors duration-300\"><div class=\"space-y-3\"><h3 class=\"font-display font-semibold text-sm tracking-wide uppercase text-ink\">Thick Dermis / Oily</h3><p class=\"text-xs text-muted leading-relaxed\">Specifically designed for active lipid control and charcoal-depth cleansing without stripping surface barrier.</p></div><div class=\"border-t border-line/30 pt-3 flex items-center justify-between text-[9px] uppercase tracking-widest font-semibold\"><span class=\"text-accent\">Derm-Restore Men&#x27;s</span><span class=\"text-muted/75 font-mono\">5.6 Restorative</span></div></div><div class=\"p-6 bg-card-bg/40 border border-line/40 rounded-xl space-y-4 flex flex-col justify-between hover:border-accent/40 transition-colors duration-300\"><div class=\"space-y-3\"><h3 class=\"font-display font-semibold text-sm tracking-wide uppercase text-ink\">Uneven Texture</h3><p class=\"text-xs text-muted leading-relaxed\">Biological enzymes dissolve keratin bonds gently. Recommended 2-3 times per week.</p></div><div class=\"border-t border-line/30 pt-3 flex items-center justify-between text-[9px] uppercase tracking-widest font-semibold\"><span class=\"text-accent\">Dermal-Micro Exfoliating</span><span class=\"text-muted/75 font-mono\">5.2 Micro-Peel</span></div></div></div></section><section class=\"mt-28 border-t border-line/60 pt-20\"><div class=\"max-w-3xl mb-16 space-y-3\"><span class=\"text-xs uppercase tracking-[0.2em] font-semibold text-accent flex items-center gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-question-mark w-3.5 h-3.5\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3\"></path><path d=\"M12 17h.01\"></path></svg> Efficacy &amp; Protocol</span><h2 class=\"font-display font-semibold text-2xl md:text-4xl uppercase tracking-tight text-ink\">CLINICAL STUDY &amp; SCIENCE Q&amp;A</h2><p class=\"text-xs md:text-sm text-muted max-w-xl leading-relaxed\">An educational guide detailing the lipid barrier, cellular water retention, pH balancing, and clinical active surfactant ingredients.</p></div><div class=\"grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-10\"><div class=\"space-y-3 border-b border-line/30 pb-6 last:border-b-0 md:last:border-b border-line/35\"><h3 class=\"font-display font-semibold text-sm tracking-wide uppercase text-ink flex gap-3\"><span class=\"text-accent/60 font-mono\">0<!-- -->1</span>How does the lipid barrier repair mechanism work?</h3><p class=\"text-xs md:text-sm text-muted leading-relaxed pl-7\">Our body washes are infused with biocompatible lipids (ceramides, phytosterols, and free fatty acids) in a 3:1:1 ratio. During cleansing, rather than stripping the skin&#x27;s defense shield, these micro-fragmented lipids fit into the gaps of the cellular matrix, reinforcing your skin&#x27;s outer envelope.</p></div><div class=\"space-y-3 border-b border-line/30 pb-6 last:border-b-0 md:last:border-b border-line/35\"><h3 class=\"font-display font-semibold text-sm tracking-wide uppercase text-ink flex gap-3\"><span class=\"text-accent/60 font-mono\">0<!-- -->2</span>Why is pH 5.5 critical for body skin?</h3><p class=\"text-xs md:text-sm text-muted leading-relaxed pl-7\">Healthy skin maintains a slightly acidic pH (around 5.5) known as the acid mantle. Traditional alkaline soaps (pH 8-10) disrupt this mantle, making skin prone to dryness, flaking, and bacterial ingress. A pH of 5.5 ensures optimal enzyme activity for self-repair and hydration.</p></div><div class=\"space-y-3 border-b border-line/30 pb-6 last:border-b-0 md:last:border-b border-line/35\"><h3 class=\"font-display font-semibold text-sm tracking-wide uppercase text-ink flex gap-3\"><span class=\"text-accent/60 font-mono\">0<!-- -->3</span>Can the Exfoliating Wash be used every day?</h3><p class=\"text-xs md:text-sm text-muted leading-relaxed pl-7\">We recommend using the Dermal-Micro Exfoliating Wash 2-3 times per week. It contains natural fruit enzymes and microscopic marine minerals that lift dead cells. For daily cleansing on other days, alternate with the Bio-Fit or Aura-Glow washes to maintain barrier integrity.</p></div><div class=\"space-y-3 border-b border-line/30 pb-6 last:border-b-0 md:last:border-b border-line/35\"><h3 class=\"font-display font-semibold text-sm tracking-wide uppercase text-ink flex gap-3\"><span class=\"text-accent/60 font-mono\">0<!-- -->4</span>What makes BODYBARREL different from face cleansers?</h3><p class=\"text-xs md:text-sm text-muted leading-relaxed pl-7\">Body skin is significantly thicker than facial skin, has fewer sebaceous glands, and is subjected to constant friction from clothing. Our formulas are specifically adjusted with larger molecular surfactants that cleanse effectively without deep epidermal penetration, preventing systemic dryness.</p></div></div></section></div></main><footer class=\"bg-bg text-ink pt-20 border-t border-line/30 flex flex-col\"><div class=\"max-w-7xl mx-auto px-6 md:px-12 w-full flex-1\"><div class=\"grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-start pb-4\"><div class=\"col-span-1 lg:col-span-7 flex items-center\"><img src=\"/logo.png\" alt=\"BODYBARREL Logo\" class=\"max-h-24 md:max-h-36 w-auto object-contain\"/></div><div class=\"col-span-1 lg:col-span-5 flex flex-col space-y-6 lg:pl-8\"><div><h4 class=\"text-xs uppercase tracking-[0.2em] text-ink font-bold font-sans\">SUBSCRIBE TO OUR NEWSLETTERS</h4><form class=\"mt-4 flex flex-col sm:flex-row items-end sm:items-center space-y-4 sm:space-y-0 sm:space-x-4 w-full\"><div class=\"border-b border-ink/40 py-2 w-full\"><input type=\"email\" placeholder=\"Enter your email address\" class=\"bg-transparent border-none outline-none w-full text-xs tracking-wider placeholder:text-ink/45 text-ink uppercase\" required=\"\" value=\"\"/></div><button type=\"submit\" class=\"relative overflow-hidden cursor-pointer select-none transition-colors duration-300 border border-line group border border-ink/80 py-2.5 px-8 text-xs uppercase tracking-widest font-semibold cursor-pointer shrink-0 w-full sm:w-auto font-sans\" style=\"isolation:isolate\"><span class=\"absolute inset-0 z-0 bg-[#e8c5c1] pointer-events-none\" style=\"transform:translateY(-110%)\"></span><span class=\"absolute inset-0 z-0 bg-[#2d1c14] pointer-events-none\" style=\"transform:translateY(-110%)\"></span><span class=\"relative z-10 w-full h-full flex items-center justify-center gap-2 pointer-events-none transition-colors duration-300 text-inherit group-hover:text-[#F6F4EE]\">SUBMIT</span></button></form></div><div class=\"flex items-center space-x-2 text-[11px] tracking-[0.2em] font-semibold text-ink font-sans pt-2\"><span class=\"text-ink/65 uppercase\">SHOP IN:</span><button class=\"inline-flex items-center justify-center whitespace-nowrap transition-all duration-300 focus-visible:outline-hidden focus-visible:ring-1 focus-visible:ring-accent disabled:pointer-events-none disabled:opacity-50 border-0 border-b border-ink/45 rounded-none px-0 py-0.5 h-auto text-[11px] font-bold text-ink uppercase tracking-widest bg-