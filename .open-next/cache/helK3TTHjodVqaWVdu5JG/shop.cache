{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/shop/layout,_N_T_/shop/page,_N_T_/shop"},"segmentPaths":["/_tree","/_full","/shop/__PAGE__","/shop","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\" class=\"antialiased selection:bg-accent selection:text-bg\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" as=\"image\" href=\"/logo.png\"/><link rel=\"preload\" as=\"image\" href=\"/face_wash.png\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/2eumutora-w-k.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/3jlsyndnafvzk.js\"/><script src=\"/_next/static/chunks/1_0v6exngdege.js\" async=\"\"></script><script src=\"/_next/static/chunks/0_bdivyfur2bb.js\" async=\"\"></script><script src=\"/_next/static/chunks/1ua5armwfph8o.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-0wcsjt0qca10g.js\" async=\"\"></script><script src=\"/_next/static/chunks/1q9ewkgf_eboj.js\" async=\"\"></script><script src=\"/_next/static/chunks/2qoc_kn_izwiv.js\" async=\"\"></script><script src=\"/_next/static/chunks/0m6ch38ih6fln.js\" async=\"\"></script><script src=\"/_next/static/chunks/3tte7lhlvfih6.js\" async=\"\"></script><script src=\"/_next/static/chunks/14mrh2-p_w84d.js\" async=\"\"></script><script src=\"/_next/static/chunks/44uufk7akz-6_.js\" async=\"\"></script><script src=\"/_next/static/chunks/30dx3dx9op5is.js\" async=\"\"></script><script src=\"/_next/static/chunks/2uxnkzamjf4_5.js\" async=\"\"></script><script src=\"/_next/static/chunks/2_rn_ywy8x_d0.js\" async=\"\"></script><script src=\"/_next/static/chunks/3iw-8yzd_t_2f.js\" async=\"\"></script><link rel=\"preload\" href=\"https://fonts.googleapis.com/css2?family=Archivo:wght@400;600;700&amp;family=Inter:wght@400;500;600&amp;display=swap\" as=\"style\"/><link rel=\"preconne